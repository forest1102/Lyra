{
  "$schema": "https://turbo.build/schema.json",
  "cacheDir": ".turbo/cache",
  "globalDependencies": ["tsconfig.json", "Cargo.toml", "Cargo.lock"],
  "globalPassThroughEnv": ["LYRA_CODEX_PATH"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "check": {
      "outputs": []
    },
    "fmt:check": {
      "outputs": []
    },
    "fmt": {
      "cache": false
    },
    "build:mcp": {
      "cache": false
    },
    "build:desktop": {
      "cache": false
    },
    "@lyra/native-tooling#test": {
      "cache": false
    },
    "@lyra/native-tooling#check": {
      "cache": false
    },
    "@lyra/native-tooling#fmt:check": {
      "cache": false
    }
  }
}
