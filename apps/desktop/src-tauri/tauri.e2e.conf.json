{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeBuildCommand": "VITE_E2E=1 bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default",
        {
          "identifier": "e2e",
          "description": "WebdriverIO permissions for the isolated E2E build",
          "windows": ["main"],
          "permissions": ["wdio:default", "wdio-webdriver:default"]
        }
      ]
    }
  }
}
