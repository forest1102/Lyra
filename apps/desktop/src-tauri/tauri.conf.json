{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lyra",
  "version": "0.1.0",
  "identifier": "app.lyra.focus",
  "build": {
    "beforeDevCommand": "bun run dev:ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lyra",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/icon.icns"],
    "macOS": {
      "minimumSystemVersion": "15.0"
    },
    "resources": ["resources/supercollider/**/*"]
  }
}
