{
  "name": "@lyra/desktop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tauri dev",
    "dev:ui": "vite --host 127.0.0.1 --port 1420",
    "build": "vite build",
    "build:desktop": "tauri build --bundles app",
    "build:e2e": "tauri build --debug --no-bundle --features e2e --config src-tauri/tauri.e2e.conf.json",
    "test": "vitest run --root ../.. apps/desktop/src",
    "test:e2e": "bun e2e/run.ts",
    "typecheck": "tsc --noEmit && tsc -p e2e/tsconfig.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@wdio/cli": "^9",
    "@wdio/globals": "^9",
    "@wdio/local-runner": "^9",
    "@wdio/mocha-framework": "^9",
    "@wdio/spec-reporter": "^9",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "jsdom": "^27.2.0",
    "tsx": "^4",
    "vite": "^7.2.2"
  }
}
