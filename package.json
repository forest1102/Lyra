{
  "name": "lyra",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/desktop",
    "tooling",
    "tooling/*"
  ],
  "overrides": {
    "@wdio/native-utils": "file:tooling/wdio-native-utils-shim"
  },
  "scripts": {
    "setup": "bun install --frozen-lockfile",
    "app:dev": "bunx turbo run dev --filter=@lyra/desktop",
    "app:build": "bunx turbo run build:desktop --filter=@lyra/desktop",
    "mcp:build": "bunx turbo run build:mcp --filter=@lyra/native-tooling",
    "test:e2e": "bun run --cwd apps/desktop test:e2e",
    "verify:core": "bunx turbo run test typecheck build check fmt:check",
    "verify": "bun run verify:core && bun run test:e2e"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
